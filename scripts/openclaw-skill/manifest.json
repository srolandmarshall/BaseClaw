{
  "name": "yahoo-fantasy-baseball",
  "version": "1.0.0",
  "description": "Yahoo Fantasy Baseball automation skill for OpenClaw — daily lineup optimization, injury monitoring, waiver scouting, and weekly recaps",
  "author": "yahoo-fantasy-mcp",
  "homepage": "https://github.com/your-repo/yahoo-fantasy",
  "license": "MIT",
  "requires": {
    "python": ">=3.9",
    "services": ["yahoo-fantasy-api-server"]
  },
  "scripts": {
    "daily-lineup": {
      "command": "python3 daily-lineup.py",
      "schedule": "0 10 * * *",
      "description": "Optimize and set daily lineup"
    },
    "injury-monitor": {
      "command": "python3 injury-monitor.py",
      "schedule": "0 */4 * * *",
      "description": "Monitor injuries and suggest replacements"
    },
    "waiver-scout": {
      "command": "python3 waiver-scout.py",
      "schedule": "0 6 * * *",
      "description": "Scout waiver wire for upgrades"
    },
    "weekly-recap": {
      "command": "python3 weekly-recap.py",
      "schedule": "0 20 * * 0",
      "description": "Generate weekly matchup recap"
    }
  },
  "config_file": "config.yaml",
  "state_files": [".injury-state.json"]
}
